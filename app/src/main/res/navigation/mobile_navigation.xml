<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    android:label="@string/title_home"
    app:startDestination="@+id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.example.focuskey.ui.achievements.AchievementsActivity"
        android:label="@string/title_home"
        tools:layout="@layout/fragment_achievements" />

    <fragment
        android:id="@+id/navigation_dashboard"
        android:name="com.example.focuskey.ui.timer.TimerActivity"
        android:label="@string/title_dashboard"
        tools:layout="@layout/fragment_timer" />

    <fragment
        android:id="@+id/navigation_notifications"
        android:name="com.example.focuskey.ui.minigames.MinigamesActivity"
        android:label="@string/title_notifications"
        tools:layout="@layout/fragment_minigames" />
</navigation>