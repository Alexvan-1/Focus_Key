<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    android:label="@string/title_history"
    app:startDestination="@+id/navigation_timer">

    <fragment
        android:id="@+id/navigation_history"
        android:name="com.example.focuskey.ui.history.HistoryActivity"
        android:label="@string/title_history"
        tools:layout="@layout/fragment_history" />

    <fragment
        android:id="@+id/navigation_timer"
        android:name="com.example.focuskey.ui.timer.TimerActivity"
        android:label="@string/title_timer"
        tools:layout="@layout/fragment_timer" />

    <fragment
        android:id="@+id/navigation_minigames"
        android:name="com.example.focuskey.ui.minigames.MinigamesActivity"
        android:label="@string/title_minigames"
        tools:layout="@layout/fragment_minigames" />
</navigation>